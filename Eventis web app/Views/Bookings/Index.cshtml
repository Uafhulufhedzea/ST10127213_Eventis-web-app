@model IEnumerable<Eventis_web_app.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<h1>Bookings</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Booking</a>
</p>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group" style="max-width: 500px;">
        <input type="text" name="searchString" value="@ViewData["CurrentSearch"]" class="form-control" placeholder="Search by Booking ID or Event Name..." />
        <button type="submit" class="btn btn-outline-secondary">Search</button>
        @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()))
        {
            <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
        }
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Booking ID</th>
            <th>Booking Date</th>
            <th>Status</th>
            <th>Event Name</th>
            <th>Event Description</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Venue Name</th>
            <th>Location</th>
            <th>Capacity</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td><small>@item.BookingId.ToString().Substring(0, 8)...</small></td>
            <td>@item.BookingDate?.ToString("yyyy-MM-dd")</td>
            <td>
                @if (item.Status == "Confirmed")
                {
                    <span class="badge bg-success">@item.Status</span>
                }
                else
                {
                    <span class="badge bg-secondary">@item.Status</span>
                }
            </td>
            <td>@item.Event?.EventName</td>
            <td><small>@item.Event?.Description</small></td>
            <td>@item.Event?.StartDate?.ToString("yyyy-MM-dd")</td>
            <td>@item.Event?.EndDate?.ToString("yyyy-MM-dd")</td>
            <td>@item.Venue?.VenueName</td>
            <td>@item.Venue?.Location</td>
            <td>@item.Venue?.Capacity</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.BookingId" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Details" asp-route-id="@item.BookingId" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Delete" asp-route-id="@item.BookingId" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">No bookings found.</div>
}
